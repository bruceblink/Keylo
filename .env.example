# JWT Secret for signing tokens - CHANGE IN PRODUCTION!
JWT_SECRET=my-jwt-secret-change-in-production

# Database configuration
DATABASE_URL=postgres://keylo_user:keylo_password@localhost:5432/keylo

# Server configuration
SERVER_ADDR=127.0.0.1
SERVER_PORT=2345

# Environment (development, staging, production)
ENVIRONMENT=development

# Token expiry times (in seconds)
TOKEN_EXPIRY_SECONDS=900          # 15 minutes
REFRESH_TOKEN_EXPIRY_SECONDS=2592000  # 30 days
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=30

# Logging level
RUST_LOG=keylo=debug,axum=info

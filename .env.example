# Keylo minimal local/deployment configuration.
#
# Keylo follows convention over configuration:
# - JWT keys are read from ./keys/private.pem and ./keys/public.pem by default.
# - Database encrypted password is read from ./secrets/postgres_password.enc.
# - Database password key is read from ./secrets/database_password.key.
# - JWT_ISSUER=keylo, JWT_KEY_ID=keylo-rs256-1, ADMIN_CLIENT_ID=cli-admin-root.
# - Token lifetimes, rate limits, logging prefix, Redis prefix, and DB pool size have sane defaults.

# Required secret: seed or update the built-in management client.
ADMIN_CLIENT_SECRET=replace-with-strong-admin-secret

# Database URL should stay passwordless. Keylo decrypts the password in-process.
DATABASE_URL=postgres://keylo_user@localhost:5432/keylo

# PostgreSQL initialization settings for docker compose.
# This plaintext password file is used by PostgreSQL on first initialization only.
POSTGRES_PASSWORD_FILE=./secrets/postgres_password
POSTGRES_PORT=5432

# Redis is required in production. For local docker compose, use the mapped host port.
REDIS_URL=redis://localhost:63790
REDIS_PORT=63790

# Common local overrides.
ENVIRONMENT=development
SERVER_PORT=2345
RUST_LOG=keylo=debug,axum=info

# Optional overrides. Uncomment only when the convention is not enough.
# ADMIN_CLIENT_ID=cli-admin-root
# JWT_ISSUER=keylo
# JWT_KEY_ID=keylo-rs256-1
# JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_PATH=./keys/public.pem
# DATABASE_PASSWORD_ENC_FILE=./secrets/postgres_password.enc
# DATABASE_PASSWORD_KEY_FILE=./secrets/database_password.key
# POSTGRES_USER=keylo_user
# POSTGRES_DB=keylo
# JWT_KEYS_DIR=./keys
# LOGS_DIR=./logs
# DB_POOL_SIZE=10
# TOKEN_EXPIRY_SECONDS=900
# REFRESH_TOKEN_EXPIRY_SECONDS=2592000
# SERVICE_TOKEN_EXPIRY_SECONDS=3600
# TRUST_PROXY_HEADERS=false
# ALLOW_IN_MEMORY_FALLBACK=false
# LOG_TO_FILE=true
# LOG_DIR=./logs
# LOG_FILE_PREFIX=keylo

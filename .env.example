# Keylo minimal local/deployment configuration.
#
# Keylo follows convention over configuration:
# - JWT keys are read from ./keys/private.pem and ./keys/public.pem by default.
# - Database encrypted password is read from ./.secrets/.database_password.enc.
# - Database password key is read from ./.secrets/.database_password.key.
# - JWT_ISSUER=keylo, JWT_KEY_ID=keylo-rs256-1, ADMIN_CLIENT_ID=cli-admin-root.
# - Token lifetimes, rate limits, logging prefix, Redis prefix, and DB pool size have sane defaults.

# Management client ID. If ADMIN_CLIENT_SECRET is omitted, enter it in the setup page.
# If ADMIN_CLIENT_SECRET is set, setup initialization can read it from this configuration.
ADMIN_CLIENT_ID=cli-admin-root

# Docker Compose host port mapping for Keylo/Postgres.
# Redis is not published by docker-compose.yml; docker-compose.dev.yml maps it to 127.0.0.1 only.
POSTGRES_PORT=5432
REDIS_PORT=63790

# Common local overrides.
ENVIRONMENT=development
SERVER_PORT=2345
KEYLO_RUST_LOG=keylo=debug,axum=info,tower_http=info

# Redis is reachable by the keylo container through a private Compose network.
# Generate Redis ACL and encrypted Redis password without writing the plain password:
#   python scripts/secret_tool.py generate-redis

# If you run Keylo on the host during local development, point Redis host/port
# at your local or test Redis. The encrypted secret contains only the password.
# REDIS_HOST=127.0.0.1
# REDIS_PORT=63790
# REDIS_USERNAME=keylo
# REDIS_DATABASE=0
# REDIS_PASSWORD_ENC_FILE=./.secrets/.redis_password.enc
# REDIS_PASSWORD_KEY_FILE=./.secrets/.redis_password.key

# Optional overrides. Uncomment only when the convention is not enough.
# DATABASE_URL=postgres://keylo_user@localhost:5432/keylo
# JWT_ISSUER=keylo
# JWT_KEY_ID=keylo-rs256-1
# JWT_AUDIENCES=admin-backend,crawler
# JWT_PRIVATE_KEY_PATH=./keys/private.pem
# JWT_PUBLIC_KEY_PATH=./keys/public.pem
# DATABASE_PASSWORD_ENC_FILE=./.secrets/.database_password.enc
# DATABASE_PASSWORD_KEY_FILE=./.secrets/.database_password.key
# REDIS_PASSWORD_ENC_FILE=./.secrets/.redis_password.enc
# REDIS_PASSWORD_KEY_FILE=./.secrets/.redis_password.key
# DB_POOL_SIZE=10
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# TOKEN_EXPIRY_SECONDS=900
# REFRESH_TOKEN_EXPIRY_SECONDS=2592000
# SERVICE_TOKEN_EXPIRY_SECONDS=3600
# TRUST_PROXY_HEADERS=false
# ALLOW_IN_MEMORY_FALLBACK=false
# ENABLE_SETUP_WIZARD=true
# LOG_TO_FILE=true
# LOG_DIR=./logs
# LOG_FILE_PREFIX=keylo

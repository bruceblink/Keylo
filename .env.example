# JWT issuer and RSA key configuration.
# Development mode can omit these and use the built-in development keypair.
# Production must explicitly provide a private/public keypair.
# Example generation:
#   mkdir -p keys
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out keys/private.pem
#   openssl rsa -pubout -in keys/private.pem -out keys/public.pem
JWT_ISSUER=keylo
JWT_KEY_ID=keylo-rs256-1
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
# JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Database configuration
# Keep DATABASE_URL passwordless. Keylo reads an encrypted password and decrypts it in-process.
DATABASE_URL=postgres://keylo_user@localhost:5432/keylo
DATABASE_PASSWORD_ENC_FILE=./secrets/postgres_password.enc
DATABASE_PASSWORD_KEY_FILE=./secrets/database_password.key

# Optional docker-compose postgres host mapping and init params
POSTGRES_PORT=5432
POSTGRES_USER=keylo_user
# Postgres initialization still needs the plaintext password secret on first startup.
POSTGRES_PASSWORD_FILE=./secrets/postgres_password
POSTGRES_DB=keylo

# Server configuration
SERVER_ADDR=127.0.0.1
SERVER_PORT=2345

# Environment (development, staging, production)
ENVIRONMENT=production

# Database pool size
DB_POOL_SIZE=20

# Token expiry times (in seconds)
# 900 = 15 minutes, 2592000 = 30 days
TOKEN_EXPIRY_SECONDS=900
REFRESH_TOKEN_EXPIRY_SECONDS=2592000
MAX_FAILED_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=300
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=30
AUTH_GLOBAL_RATE_LIMIT_MAX_REQUESTS=300

# Optional admin client seed (recommended for management APIs)
ADMIN_CLIENT_ID=cli-admin-root
ADMIN_CLIENT_SECRET=replace-with-strong-admin-secret

# Optional Redis for distributed rate-limit/lockout/OAuth-state storage
# Local cargo run: if using docker-compose redis mapped to host, use REDIS_PORT below
REDIS_URL=redis://localhost:63790
REDIS_KEY_PREFIX=keylo
AUDIT_LOG_RETENTION_DAYS=30

# Docker Compose redis host port mapping (host:container = REDIS_PORT:6379)
REDIS_PORT=63790

# Docker Compose key mount source directory
JWT_KEYS_DIR=./keys

# ------------------------------------------------------------
# Compose and local now share the same variable names.
# For compose-internal service discovery, override if needed:
# DATABASE_URL=postgres://keylo_user@postgres:5432/keylo
# REDIS_URL=redis://redis:6379
# ------------------------------------------------------------

# Logging level
RUST_LOG=keylo=debug,axum=info
